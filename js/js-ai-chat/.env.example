# ─── Project-specific settings ────────────────────────────────────────────────
PORT=3000
HOST=127.0.0.1
DATABASE_URL=file:.data/agent.db

# Request limits
BODY_LIMIT=1048576
TIMEOUT_MS=60000

# CORS
CORS_ORIGIN=*

# ─── Observability (optional) ─────────────────────────────────────────────────
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ─── AI provider keys ─────────────────────────────────────────────────────────
# Set these in the workspace root .env (one level above this project), not here.
# The server loads the root .env automatically on startup.
#
# Example root .env:
#   OPENAI_API_KEY=sk-...
#   OPENROUTER_API_KEY=sk-or-v1-...   # use instead of / alongside OPENAI_API_KEY
#   GEMINI_API_KEY=AIza...
#
# To select a provider or model, also add to root .env:
#   AI_PROVIDER=openrouter            # defaults to openai when OPENAI_API_KEY is set
#   DEFAULT_MODEL=openrouter:gpt-5.4  # format: "provider:model"
