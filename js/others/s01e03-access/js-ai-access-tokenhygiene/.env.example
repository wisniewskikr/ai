# OpenRouter — used by local proxy only, never by the app directly
OPENROUTER_API_KEY=your-openrouter-key-here

# Admin key — to manage the proxy (create/revoke virtual keys)
PROXY_ADMIN_KEY=sk-master-change-me

# Virtual keys — scoped per service, created via: npm run setup-keys
CHAT_API_KEY=
ANALYZER_API_KEY=
WRITER_API_KEY=
