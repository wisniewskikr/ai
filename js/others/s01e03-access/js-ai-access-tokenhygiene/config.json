{
  "services": {
    "chat": {
      "tokenName": "CHAT_TOKEN",
      "apiKeyEnvVar": "CHAT_API_KEY",
      "model": "anthropic/claude-haiku-4-5",
      "ttlMinutes": 5
    },
    "analyzer": {
      "tokenName": "ANALYZER_TOKEN",
      "apiKeyEnvVar": "ANALYZER_API_KEY",
      "model": "anthropic/claude-haiku-4-5",
      "ttlMinutes": 2
    },
    "writer": {
      "tokenName": "WRITER_TOKEN",
      "apiKeyEnvVar": "WRITER_API_KEY",
      "model": "anthropic/claude-sonnet-4-6",
      "ttlMinutes": 10
    }
  },
  "proxy": {
    "baseUrl": "http://localhost:4000",
    "maxTokens": 64
  },
  "logging": {
    "dir": "logs",
    "file": "app.log"
  }
}
