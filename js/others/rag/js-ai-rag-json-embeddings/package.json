{
  "name": "js-ai-rag-json-embeddings",
  "version": "1.0.0",
  "description": "RAG chat — answers questions from a personal knowledge file",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node -r dotenv/config dist/index.js",
    "start:build-embeddings": "node -r dotenv/config dist/index.js build",
    "start:chat": "node -r dotenv/config dist/index.js chat",
    "dev": "ts-node -r dotenv/config src/index.ts",
    "dev:build-embeddings": "ts-node -r dotenv/config src/index.ts build",
    "dev:chat": "ts-node -r dotenv/config src/index.ts chat"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
